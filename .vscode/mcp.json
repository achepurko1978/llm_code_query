{
  "servers": {
    "clang-cpp": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "-u",
        "${workspaceFolder}/llm_code_query/mcp_server.py",
        "--workspace-root",
        "${workspaceFolder}",
        "--tools-json",
        "${workspaceFolder}/llm_code_query/tools.json",
        "--clang-script",
        "${workspaceFolder}/llm_code_query/clang_mcp.py",
        "--backend-timeout",
        "12"
      ]
    }
  }
}
