{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cpp-mcp-v1.schema.json",
  "title": "C++ MCP v1",
  "$defs": {
    "Entity": {
      "type": "string",
      "enum": [
        "class",
        "struct",
        "function",
        "method",
        "constructor",
        "destructor",
        "field",
        "variable",
        "parameter",
        "call",
        "enum",
        "namespace",
        "file"
      ]
    },
    "Action": {
      "type": "string",
      "enum": [
        "find",
        "list",
        "count",
        "exists"
      ]
    },
    "Access": {
      "type": "string",
      "enum": [
        "public",
        "protected",
        "private"
      ]
    },
    "Status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "Warning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    },
    "Location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "file"
      ]
    },
    "Page": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "next_cursor": {
          "type": [
            "string",
            "null"
          ]
        },
        "truncated": {
          "type": "boolean"
        },
        "total_matches": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "next_cursor",
        "truncated",
        "total_matches"
      ]
    },
    "ParameterSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "symbol_id": {
          "type": "string"
        },
        "entity": {
          "const": "parameter"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "position": {
          "type": "integer",
          "minimum": 0
        },
        "location": {
          "$ref": "#/$defs/Location"
        }
      },
      "required": [
        "entity",
        "name",
        "type",
        "position"
      ]
    },
    "RelationSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string"
        },
        "symbol_id": {
          "type": "string"
        },
        "entity": {
          "$ref": "#/$defs/Entity",
          "description": "Target entity kind. Important: entity=method returns regular methods only and excludes constructors/destructors. To list all member functions, run separate queries for entity=method, entity=constructor, and entity=destructor, then merge results."
        },
        "name": {
          "type": "string"
        },
        "qualified_name": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/Location"
        }
      },
      "required": [
        "kind",
        "symbol_id",
        "entity",
        "name"
      ]
    },
    "SymbolSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "symbol_id": {
          "type": "string"
        },
        "entity": {
          "$ref": "#/$defs/Entity"
        },
        "name": {
          "type": "string"
        },
        "qualified_name": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        },
        "return_type": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/Location"
        },
        "summary": {
          "type": "string"
        },
        "access": {
          "$ref": "#/$defs/Access"
        },
        "static": {
          "type": "boolean"
        },
        "const": {
          "type": "boolean"
        },
        "virtual": {
          "type": "boolean"
        },
        "override": {
          "type": "boolean"
        },
        "deleted": {
          "type": "boolean"
        },
        "defaulted": {
          "type": "boolean"
        },
        "implicit": {
          "type": "boolean"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ParameterSummary"
          }
        },
        "source": {
          "type": "string",
          "description": "Full source text of the symbol (declaration + body). Only present when include_source=true in the request."
        },
        "extent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start_line": {
              "type": "integer",
              "minimum": 1
            },
            "end_line": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": ["start_line", "end_line"],
          "description": "Line range of the symbol in the source file. Only present when include_source=true."
        },
        "relations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "calls": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/RelationSummary"
              }
            },
            "called_by": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/RelationSummary"
              }
            },
            "derives_from": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/RelationSummary"
              }
            },
            "overrides": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/RelationSummary"
              }
            },
            "contains": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/RelationSummary"
              }
            }
          }
        }
      },
      "required": [
        "symbol_id",
        "entity",
        "name"
      ]
    },
    "Scope": {
      "type": "object",
      "description": "WHERE to look — narrows the search to a file, directory, function, class, or namespace. Use scope.file for file/directory filtering. Do NOT put file paths in 'where'.",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Workspace-root-relative file path or directory path (e.g. 'VSC/FdcSP/src/Foo.cpp' or 'VSC/FdcSP/src'). This is the ONLY place to specify file/directory scope — never put file paths in the 'where' filter."
        },
        "directory": {
          "type": "string",
          "description": "Alias for 'file' — workspace-root-relative directory path (e.g. 'VSC/FdcSP/src'). Prefer using 'file' which accepts both files and directories."
        },
        "inside_function": {
          "type": "string",
          "description": "Opaque symbol_id of containing function/method/constructor/destructor."
        },
        "inside_class": {
          "type": "string",
          "description": "Opaque symbol_id of containing class/struct."
        },
        "in_namespace": {
          "type": "string",
          "description": "Namespace name or symbol_id."
        }
      }
    },
    "RelationsFilter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "derives_from": {
          "type": "string",
          "description": "Base class symbol_id or qualified name."
        },
        "overrides": {
          "type": "string",
          "description": "Base method symbol_id."
        },
        "calls": {
          "type": "string",
          "description": "Target callable symbol_id."
        },
        "called_by": {
          "type": "string",
          "description": "Caller symbol_id."
        }
      }
    },
    "Where": {
      "type": "object",
      "description": "WHAT to match — filters symbols by their properties (name, return_type, access, etc.). Do NOT put file paths here; use 'scope.file' instead.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "qualified_name": {
          "type": "string"
        },
        "return_type": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "param_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "static": {
          "type": "boolean"
        },
        "const": {
          "type": "boolean"
        },
        "virtual": {
          "type": "boolean"
        },
        "override": {
          "type": "boolean"
        },
        "deleted": {
          "type": "boolean"
        },
        "defaulted": {
          "type": "boolean"
        },
        "implicit": {
          "type": "boolean"
        },
        "access": {
          "$ref": "#/$defs/Access"
        },
        "relations": {
          "$ref": "#/$defs/RelationsFilter"
        },
        "any_of": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "BaseResponse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/Status"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Warning"
          }
        }
      },
      "required": [
        "status",
        "warnings"
      ]
    },
    "CppResolveSymbolRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "entity": {
          "$ref": "#/$defs/Entity"
        },
        "qualified_name": {
          "type": "string"
        },
        "file": {
          "type": "string"
        },
        "param_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50000,
          "default": 5000
        }
      },
      "required": [
        "name"
      ]
    },
    "CppResolveSymbolResponse": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseResponse"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "$ref": "#/$defs/Status"
            },
            "result_kind": {
              "const": "resolve_symbol"
            },
            "ambiguous": {
              "type": "boolean"
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/SymbolSummary"
              }
            },
            "warnings": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Warning"
              }
            },
            "page": {
              "$ref": "#/$defs/Page"
            }
          },
          "required": [
            "status",
            "result_kind",
            "ambiguous",
            "items",
            "warnings",
            "page"
          ]
        }
      ]
    },
    "CppSemanticQueryRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/$defs/Action"
        },
        "entity": {
          "$ref": "#/$defs/Entity"
        },
        "scope": {
          "$ref": "#/$defs/Scope",
          "description": "WHERE to look: narrows search to a file, directory, class, or namespace. Put file/directory paths here in scope.file, NOT in 'where'."
        },
        "where": {
          "$ref": "#/$defs/Where",
          "description": "WHAT to match: filters by symbol properties like name, return_type, access, static, const, etc. Do NOT put file paths here."
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50000,
          "default": 5000
        },
        "cursor": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "symbol_id",
              "entity",
              "name",
              "qualified_name",
              "signature",
              "return_type",
              "type",
              "parameters",
              "access",
              "static",
              "const",
              "virtual",
              "override",
              "deleted",
              "defaulted",
              "implicit",
              "location",
              "source",
              "extent"
            ]
          },
          "description": "Optional subset of fields to include per result item. Only the requested fields are returned. Include \"symbol_id\" if you need to pass results to cpp_describe_symbol. Omitting this returns all fields. For listing method names use: [\"qualified_name\", \"signature\", \"access\"]. Important: this method listing excludes constructors/destructors; query entity=constructor and entity=destructor separately and merge if you want all member functions. For follow-up describe calls use: [\"symbol_id\", \"qualified_name\", \"signature\", \"access\"]."
        },
        "include_source": {
          "type": "boolean",
          "default": false,
          "description": "When true, each result item includes a 'source' field with the full source text and an 'extent' field with start_line/end_line. Opt-in to avoid large responses."
        }
      },
      "required": [
        "action",
        "entity"
      ]
    },
    "CppSemanticQueryResponse": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseResponse"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "$ref": "#/$defs/Status"
            },
            "result_kind": {
              "$ref": "#/$defs/Action"
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/SymbolSummary"
              }
            },
            "count": {
              "type": "integer",
              "minimum": 0
            },
            "exists": {
              "type": "boolean"
            },
            "warnings": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Warning"
              }
            },
            "page": {
              "$ref": "#/$defs/Page"
            }
          },
          "required": [
            "status",
            "result_kind",
            "warnings"
          ],
          "allOf": [
            {
              "if": {
                "properties": {
                  "result_kind": {
                    "enum": [
                      "find",
                      "list"
                    ]
                  }
                },
                "required": [
                  "result_kind"
                ]
              },
              "then": {
                "required": [
                  "items",
                  "page"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "result_kind": {
                    "const": "count"
                  }
                },
                "required": [
                  "result_kind"
                ]
              },
              "then": {
                "required": [
                  "count"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "result_kind": {
                    "const": "exists"
                  }
                },
                "required": [
                  "result_kind"
                ]
              },
              "then": {
                "required": [
                  "exists"
                ]
              }
            }
          ]
        }
      ]
    },
    "CppDescribeSymbolRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "symbol_id": {
          "type": "string"
        },
        "include_relations": {
          "type": "boolean",
          "default": true
        },
        "relation_limit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 50000,
          "default": 5000
        },
        "include_source": {
          "type": "boolean",
          "default": false,
          "description": "When true, the response item includes a 'source' field with the full source text and an 'extent' field with start_line/end_line."
        }
      },
      "required": [
        "symbol_id"
      ]
    },
    "CppDescribeSymbolResponse": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseResponse"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "$ref": "#/$defs/Status"
            },
            "result_kind": {
              "const": "describe_symbol"
            },
            "item": {
              "$ref": "#/$defs/SymbolSummary"
            },
            "warnings": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Warning"
              }
            }
          },
          "required": [
            "status",
            "result_kind",
            "item",
            "warnings"
          ]
        }
      ]
    }
  }
}
